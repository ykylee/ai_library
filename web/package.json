{
  "name": "ai-library-web",
  "version": "0.3.0",
  "description": "ai_library standalone management frontend (SvelteKit 2 + Svelte 5 + TypeScript 5)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "lint": "echo 'lint M-v0.2.1+ scope'"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^3.2.0",
    "@sveltejs/kit": "^2.5.0",
    "@sveltejs/vite-plugin-svelte": "^3.1.0",
    "@types/node": "^20.12.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
