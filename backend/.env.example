# ai_library backend — env example
# 실제 시크릿 값은 .env.local (gitignored) 또는 vault 에서 관리

# === Server ===
AI_LIBRARY_HOST=0.0.0.0
AI_LIBRARY_PORT=8000
AI_LIBRARY_RELOAD=true
AI_LIBRARY_LOG_LEVEL=info

# === Repo root (4-priority auto-detect) ===
# 1) --repo-root flag
# 2) AI_LIBRARY_REPO_ROOT env
# 3) git rev-parse --show-toplevel
# 4) legacy fallback (1회 stderr deprecation warning)
# AI_LIBRARY_REPO_ROOT=/Users/yklee/repos/ai_library

# === Storage mode (M-v0.3.0+ default file-based) ===
# AI_LIBRARY_STORAGE_MODE=file
# AI_LIBRARY_VAR_DIR=./var

# === Source plugin (5종) ===
# Gitea 4 sub-plugin
# 사외 tier 정책상 실제 사내 호스트는 placeholder 로 유지.
# 실제 값은 .env.local (gitignored) 에서만 주입. 사외 repo 에 사내 호스트 단일 occurrence ❌.
# AI_LIBRARY_GITEA_URL=https://<your-gitea-host>
# AI_LIBRARY_GITEA_TOKEN=<from-vault>
# AI_LIBRARY_GITEA_OWNER=<gitea-owner>
# AI_LIBRARY_GITEA_REPOS=<repo1>,<repo2>
# AI_LIBRARY_GITEA_ISSUES=true
# AI_LIBRARY_GITEA_WIKI=false
# AI_LIBRARY_GITEA_ACTIONS=false

# Metrics (M-v0.3.2+ 옵션)
# AI_LIBRARY_METRICS_URL=http://prometheus.example.com
# AI_LIBRARY_METRICS_QUERY=up

# HRDB (M-v0.3.2+ 옵션, PII detection 활성화 시)
# AI_LIBRARY_HRDB_URL=http://hrdb.example.com
# AI_LIBRARY_HRDB_API_KEY=<from-vault>

# === Pi LLM enrich (M-v0.3.1+) ===
# AI_LIBRARY_PI_MODE=sdk  # sdk | rpc
# AI_LIBRARY_PI_RPC_URL=http://pi-rpc.example.com
# PI_API_KEY=<from-vault>
